## Supabase Docker .env template (DOCUMENTATION ONLY — DO NOT COMMIT SECRETS)
# This template lists required variables and recommended generation commands.
# Fill the required values from a secrets manager or local secure storage.
# For production, never store real secret values in git.

# ------------------------
# Database
# ------------------------
POSTGRES_DB=db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=            # REQUIRED — Postgres password (use letters+numbers)

# ------------------------
# JWT / API keys
# ------------------------
JWT_SECRET=                    # REQUIRED — JWT signing secret (generate securely)
ANON_KEY=                      # REQUIRED — client anon key (keep public-limited)
SERVICE_ROLE_KEY=              # REQUIRED — server service_role key (never expose)

# ------------------------
# Encryption / internal keys
# ------------------------
# `SECRET_KEY_BASE` must be at least 64 characters
SECRET_KEY_BASE=
# `VAULT_ENC_KEY` must be exactly 32 hex characters (openssl rand -hex 16)
VAULT_ENC_KEY=
# `PG_META_CRYPTO_KEY` must be at least 32 characters
PG_META_CRYPTO_KEY=

# ------------------------
# Public URLs (set to your real HTTPS domain)
# ------------------------
SUPABASE_PUBLIC_URL=https://example.com
API_EXTERNAL_URL=https://example.com
SITE_URL=https://example.com

# ------------------------
# Dashboard (Studio)
# ------------------------
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=            # REQUIRED — change default; must include at least one letter

# ------------------------
# Ports & optional settings
# ------------------------
POSTGRES_PORT=5432
POOLER_PROXY_PORT_TRANSACTION=6543
KONG_HTTP_PORT=8000

# ------------------------
# Optional integration tokens (leave blank or use secrets manager)
# ------------------------
LOGFLARE_PUBLIC_ACCESS_TOKEN=
LOGFLARE_PRIVATE_ACCESS_TOKEN=
S3_PROTOCOL_ACCESS_KEY_ID=
S3_PROTOCOL_ACCESS_KEY_SECRET=
MINIO_ROOT_PASSWORD=

# ------------------------
# Functions / runtime flags
# ------------------------
FUNCTIONS_VERIFY_JWT=true

# ------------------------
# Helpful commands (examples) — run locally to generate strong secrets
# ------------------------
# Generate a SECRET_KEY_BASE (~64 chars):
#   openssl rand -base64 48
# Generate VAULT_ENC_KEY (32 hex chars):
#   openssl rand -hex 16
# Generate a JWT secret (base64 or hex):
#   openssl rand -base64 48

# ------------------------
# Notes
# ------------------------
# - Review and run `sh ./utils/generate-keys.sh` in the upstream repo to auto-generate many keys.
# - Do NOT commit this file with real secret values. Add any local copy to .gitignore.
