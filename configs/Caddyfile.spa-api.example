{
	# Global options — adjust email for ACME notifications
	email admin@example.com
}

your-spa-domain.example.com {
	encode zstd gzip

	# Security headers
	header {
		-Server
		X-Content-Type-Options nosniff
		X-Frame-Options SAMEORIGIN
		Referrer-Policy strict-origin-when-cross-origin
	}

	# Serve SPA assets from this directory
	root * /var/www/site

	# Simple health endpoint used by tooling
	handle /up {
		respond "OK" 200
	}

	# Proxy API requests to your Node.js backend.
	# NOTE: This routes only /api/* to the backend.
	reverse_proxy /api/* 127.0.0.1:3000

	# --- Supabase Kong/Lambda variant (optional) ---
	# If you want your SPA to talk to Supabase via the Supabase docker gateway
	# (Kong) instead of your Node.js API, you typically want to STRIP the
	# leading /api prefix.
	#
	# Example SPA calls:
	# - /api/auth/v1/...  -> Kong receives /auth/v1/...
	# - /api/rest/v1/...  -> Kong receives /rest/v1/...
	# - /api/functions/v1/<name>/... -> Kong receives /functions/v1/<name>/...
	#
	# To enable this variant, comment out the Node.js reverse_proxy line above
	# and uncomment the block below.
	# handle_path /api/* {
	#   reverse_proxy 127.0.0.1:8000
	# }

	# SPA fallback: serve index.html for non-file routes.
	try_files {path} /index.html
	file_server
}
